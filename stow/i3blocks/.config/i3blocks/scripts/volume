#!/usr/bin/env bash
# Default sink volume / mute state via pactl (works with PipeWire-pulse too).
if ! command -v pactl >/dev/null 2>&1; then
  echo "VOL n/a"; exit 0
fi
mute=$(pactl get-sink-mute @DEFAULT_SINK@ 2>/dev/null | awk '{print $2}')
vol=$(pactl get-sink-volume @DEFAULT_SINK@ 2>/dev/null \
       | awk -F'/' 'NR==1{gsub(/[ %]/,"",$2); print $2}')
if [ "$mute" = "yes" ]; then
  echo "VOL muted"
else
  echo "VOL ${vol:-?}%"
fi
