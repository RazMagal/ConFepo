# ~/.config/dunst/dunstrc — managed by confepo  (Catppuccin Mocha)

[global]
    monitor = 0
    follow = mouse
    width = 340
    height = 300
    origin = top-right
    offset = 14x42
    scale = 0
    notification_limit = 5

    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 320

    indicate_hidden = yes
    transparency = 8
    separator_height = 2
    padding = 10
    horizontal_padding = 12
    frame_width = 2
    frame_color = "#89b4fa"
    gap_size = 6
    separator_color = frame
    sort = yes

    font = FiraCode Nerd Font 10
    line_height = 0
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    icon_position = left
    min_icon_size = 0
    max_icon_size = 48
    enable_recursive_icon_lookup = true
    icon_theme = "Papirus-Dark, Adwaita"

    corner_radius = 10
    mouse_left_click = do_action, close_current
    mouse_middle_click = do_action, open_url
    mouse_right_click = close_all

[urgency_low]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#45475a"
    timeout = 6

[urgency_normal]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#89b4fa"
    timeout = 8

[urgency_critical]
    background = "#1e1e2e"
    foreground = "#f38ba8"
    frame_color = "#f38ba8"
    timeout = 0
